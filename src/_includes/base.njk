<!DOCTYPE html>
<html lang="{{ site.lang | default('en') }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="{{ description or site.description }}">

  <title>{{ title }}</title>

  <!-- Design system — tokens first, then base -->
  <link rel="stylesheet" href="/css/tokens/color.css">
  <link rel="stylesheet" href="/css/tokens/type.css">
  <link rel="stylesheet" href="/css/tokens/space.css">
  <link rel="stylesheet" href="/css/tokens/motion.css">
  <link rel="stylesheet" href="/css/base/fonts.css">
  <link rel="stylesheet" href="/css/base/reset.css">
  <link rel="stylesheet" href="/css/base/type.css">
  <link rel="stylesheet" href="/css/base/layout.css">

  <!-- Site-specific styles -->
  <link rel="stylesheet" href="/css/site.css">

  <!-- Page-specific styles -->
  {% if pageCss %}
    <link rel="stylesheet" href="/css/{{ pageCss }}">
  {% endif %}
</head>
<body>

  <a href="#main" id="skip-link" class="visually-hidden">Skip to content</a>

  <div class="container">

    <header>
      <p class="site-title"><a href="/">{{ site.name }}</a></p>
<nav aria-label="Main Navigation">
  <ul class="nav">
    <li {% if page.url == "/" %}class="current-page"{% endif %}><a href="/">Home</a></li>
    <li {% if page.url == "/about" %}class="current-page"{% endif %}><a href="/about">About</a></li>
    <li><a href="/connect/">Connect</a></li>
    <li><a href="/connect/email/">Email Us</a></li>
    <li><a href="/connect/donate/">Donate</a></li>
    <li><a href="/connect/calendar/">Calendar</a></li>
    <li><a href="/connect/visit/">Visit Us</a></li>
  </ul>
</nav>
    </header>

    <main id="main" class="flow">
      {% block content %}{% endblock %}
    </main>

    <footer>
      <p>© {{ site.author }}</p>
    </footer>

  </div>

</body>
</html>